    },
    {
      "group": "sound_environment",
      "source_games": ["halo3_mcc", "halo3odst_mcc"],
      "target_games": ["halo4_mcc", "halo2amp_mcc"],
      "reason": "Halo 3 uses authored room/reverb scalars while Halo 4 and H2A use a WWise environment name and wet-mix controls; there is no lossless semantic mapping."
    },
    {
      "group": "vision_mode",
      "source_games": ["halo3odst_mcc", "haloreach_mcc"],
      "target_games": ["halo4_mcc", "halo2amp_mcc"],
      "reason": "The legacy radius, ping, color, and mask fields were replaced by Halo 4's screen, environment, biped, vehicle, and crosshair pass blocks."
    }
